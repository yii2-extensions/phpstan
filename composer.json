{
    "name": "yii2-extensions/phpstan",
    "type": "library",
    "description": "PHPStan extension for Yii2",
    "keywords": [
        "yii2",
        "phpstan"
    ],
    "license": "BSD-3-Clause",
    "authors": [
        {
            "name": "Wilmer Arambula",
            "email": "terabytesoftw@gmail.com",
            "homepage": "https://github.com/terabytesoftw",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.1",
        "nikic/php-parser": "^4.1|^5.4",
        "phpstan/phpstan": "^2.2",
        "yiisoft/yii2": "2.0.*@dev || ^22.0@dev"
    },
    "require-dev": {
        "maglnet/composer-require-checker": "^4.7",
        "php-forge/coding-standard": "^0.3",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0.3",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "yii2\\extensions\\phpstan\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "yii2\\extensions\\phpstan\\tests\\": "tests"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.5.x-dev"
        },
        "phpstan": {
            "includes": [
                "extension.neon"
            ]
        },
        "scaffold": {
            "allowed-packages": [
                "php-forge/baseline",
                "php-forge/coding-standard"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "ondrejmirtes/composer-attribute-collector": true,
            "yii2-extensions/scaffold": true,
            "yiisoft/yii2-composer": true
        }
    },
    "scripts": {
        "check-dependencies": "./vendor/bin/composer-require-checker check",
        "ecs": "./vendor/bin/ecs --fix",
        "rector": "./vendor/bin/rector process",
        "static": "./vendor/bin/phpstan --memory-limit=-1",
        "tests": "php -d memory_limit=-1 ./vendor/bin/phpunit"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ]
}
