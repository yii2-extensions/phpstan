{
    "tabWidth": 4,
    "useTabs": false,
    "singleQuote": false,
    "trailingComma": "all",
    "printWidth": 80,
    "overrides": [
        {
            "files": ["**/*.{js,jsx,ts,tsx,vue,css,scss,html,yml,yaml}"],
            "options": {
                "tabWidth": 2
            }
        },
        {
            "files": "**/*.md",
            "options": {
                "embeddedLanguageFormatting": "off",
                "tabWidth": 2
            }
        },
        {
            "files": ["**/package.json", "**/package-lock.json"],
            "options": {
                "tabWidth": 2
            }
        }
    ]
}
